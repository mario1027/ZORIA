"""
Página principal del Simulador RLC
Usando el estilo de la plantilla Volt
"""
from dash import html, callback, Input, Output, State, register_page
from dash.exceptions import PreventUpdate
import plotly.graph_objects as go
from plotly.subplots import make_subplo# Función para registrar todos los callbacks
def register_callbacks(app):
    """Registra todos los callbacks de la página del simulador"""
    
    # Callback para forzar recálculo cuando cambia el tipo de circuito
    @app.callback(
        Output('calculate-btn', 'n_clicks'),
        [Input('circuit-type', 'value')],
        prevent_initial_call=True
    )
    def force_recalculation(circuit_type):
        """Fuerza recálculo cuando cambia el tipo de circuito"""
        if circuit_type and not circuit_type.startswith('header'):
            # Simular un click en el botón para forzar recálculo
            return 1
        return 0

    # Callback principal de cálculo
    @app.callback(
        [Output('bode-plot', 'figure'),
         Output('nyquist-plot', 'figure'),
         Output('impedance-info', 'children')],
        [Input('calculate-btn', 'n_clicks'),
         Input('circuit-type', 'value'),
         Input('resistance-input', 'value'),
         Input('inductance-input', 'value'),
         Input('capacitance-input', 'value'),
         Input('freq-start', 'value'),
         Input('freq-end', 'value'),
         Input('freq-points', 'value')],
        prevent_initial_call=False
    )
    def calculate_impedance(n_clicks, circuit_type, R, L, C, f_start, f_end, n_points):
        """Calcula y grafica la impedancia del circuito"""
        
        print(f"\n🚀 BOTÓN PRESIONADO: n_clicks = {n_clicks}")
        print(f"📊 Datos recibidos: circuit_type={circuit_type}, R={R}, L={L}, C={C}")
        
        # Validaciones
        if not circuit_type or circuit_type.startswith('header'):
            circuit_type = 'RC_series'
            
        # Default values
        if R is None: R = 1000
        if L is None: L = 0.001  
        if C is None: C = 1e-6
        if f_start is None: f_start = 10
        if f_end is None: f_end = 100000
        if n_points is None: n_points = 100
        
        # Validar rangos
        if R <= 0: R = 1000
        if L <= 0: L = 0.001
        if C <= 0: C = 1e-6
        if f_start <= 0: f_start = 10
        if f_end <= f_start: f_end = f_start * 1000
        if n_points < 10: n_points = 10
    circuit_selector_card,
    resistance_input_card,
    inductance_input_card,
    capacitance_input_card,
    frequency_range_card,
    bode_plot_card,
    nyquist_plot_card,
    impedance_info_card
)
from .simulator.impedance_calculator import ImpedanceCalculator

# Funciones auxiliares para formateo de valores
def format_resistance(R):
    """Formatea valores de resistencia de manera legible"""
    if R >= 1000000:
        return f"{R/1000000:.3f} MΩ"
    elif R >= 1000:
        return f"{R/1000:.3f} kΩ"
    else:
        return f"{R:.3f} Ω"

def format_inductance(L):
    """Formatea valores de inductancia de manera legible"""
    if L >= 1:
        return f"{L:.3f} H"
    elif L >= 0.001:
        return f"{L*1000:.3f} mH"
    elif L >= 0.000001:
        return f"{L*1000000:.3f} μH"
    else:
        return f"{L*1000000000:.3f} nH"

def format_capacitance(C):
    """Formatea valores de capacitancia de manera legible"""
    if C >= 0.001:
        return f"{C:.3f} F"
    elif C >= 0.000001:
        return f"{C*1000:.3f} mF"
    elif C >= 0.000000001:
        return f"{C*1000000:.3f} μF"
    elif C >= 0.000000000001:
        return f"{C*1000000000:.3f} nF"
    else:
        return f"{C*1000000000000:.3f} pF"

def format_frequency(f):
    """Formatea valores de frecuencia de manera legible"""
    if f >= 1000000000:
        return f"{f/1000000000:.3f} GHz"
    elif f >= 1000000:
        return f"{f/1000000:.3f} MHz"
    elif f >= 1000:
        return f"{f/1000:.3f} kHz"
    else:
        return f"{f:.3f} Hz"

def register_simulator_page(app):
    """Registra la página del simulador después de crear la app"""
    register_page(
        __name__,
        path='/',
        title='Simulador RLC',
        name='Simulador RLC',
        layout=layout
    )
    
    # Registrar callbacks después de que la página esté registrada
    register_callbacks(app)

# Información de circuitos
CIRCUIT_INFO = {
    'R': {
        'name': 'Resistor',
        'description': 'Un resistor puro presenta impedancia constante en todas las frecuencias, sin desfase.',
        'formula': 'Z = R',
        'components': ['R']
    },
    'L': {
        'name': 'Inductor',
        'description': 'Un inductor puro presenta impedancia que aumenta linealmente con la frecuencia.',
        'formula': 'Z = jωL',
        'components': ['L']
    },
    'C': {
        'name': 'Capacitor',
        'description': 'Un capacitor puro presenta impedancia que disminuye con la frecuencia.',
        'formula': 'Z = 1/(jωC)',
        'components': ['C']
    },
    'RC_series': {
        'name': 'RC en Serie',
        'description': 'Resistor y capacitor conectados en serie. Comportamiento de filtro pasa-altos.',
        'formula': 'Z = R + 1/(jωC)',
        'components': ['R', 'C']
    },
    'RC_parallel': {
        'name': 'RC en Paralelo',
        'description': 'Resistor y capacitor conectados en paralelo. La impedancia disminuye en altas frecuencias.',
        'formula': 'Z = R / (1 + jωRC)',
        'components': ['R', 'C']
    },
    'RL_series': {
        'name': 'RL en Serie',
        'description': 'Resistor e inductor conectados en serie. Comportamiento de filtro pasa-bajos.',
        'formula': 'Z = R + jωL',
        'components': ['R', 'L']
    },
    'RL_parallel': {
        'name': 'RL en Paralelo',
        'description': 'Resistor e inductor conectados en paralelo. La impedancia disminuye en altas frecuencias.',
        'formula': 'Z = RjωL / (R + jωL)',
        'components': ['R', 'L']
    },
    'LC_series': {
        'name': 'LC en Serie',
        'description': 'Inductor y capacitor en serie. Presenta resonancia donde la impedancia es mínima.',
        'formula': 'Z = jωL + 1/(jωC)',
        'components': ['L', 'C']
    },
    'LC_parallel': {
        'name': 'LC en Paralelo',
        'description': 'Inductor y capacitor en paralelo. Presenta resonancia donde la impedancia es máxima.',
        'formula': 'Z = jωL / (1 - ω²LC)',
        'components': ['L', 'C']
    },
    'RLC_series': {
        'name': 'RLC en Serie',
        'description': 'Circuito resonante serie. Presenta resonancia con impedancia mínima igual a R.',
        'formula': 'Z = R + jωL + 1/(jωC)',
        'components': ['R', 'L', 'C']
    },
    'RLC_parallel': {
        'name': 'RLC en Paralelo',
        'description': 'Circuito resonante paralelo. Presenta resonancia con impedancia máxima.',
        'formula': 'Z = 1 / (1/R + 1/(jωL) + jωC)',
        'components': ['R', 'L', 'C']
    }
}


def format_resistance(R):
    """Formatea el valor de resistencia de manera legible"""
    if R >= 1000000:
        return f"{R/1000000:.3f} MΩ"
    elif R >= 1000:
        return f"{R/1000:.3f} kΩ"
    else:
        return f"{R:.3f} Ω"


